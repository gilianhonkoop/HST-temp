{
    "data": {
        "task":"aml_hi_small",
        "data_dir": "/home/ghonkoop/data/aml/HI-Small",
        "dataset_type": "ibm_aml",
        "aml_split": "temporal",
        "aml_train_ratio": 0.7,
        "aml_val_ratio": 0.15
    },
    "wandb": {
        "wandb_logging": true,
        "project": "ml-detection",
        "name": "aml-HI-Small-SubGNN",
        "epoch_logging": true
    },
    "tb": {
        "tb_logging":false,
        "dir" : "tensorboard",
        "name": "aml-HI-Small-SubGNN"
       
    },
    "early_stopping": {
        "enabled": true,
        "patience": 15,
        "min_delta": 0.0
    },
    "optuna":{
        "opt_n_trials" : 6,
        "opt_n_cores" : 1,
        "monitor_metric" : "val_micro_f1",
        "opt_direction" : "maximize" ,
        "sampler" : "random", 
        "pruning" : false
    },
    "run_test": true,

    "hyperparams_fix" : {
        "max_epochs": 300,
        "use_neighborhood": false, 
        "use_structure": true,
        "use_position": false,
        "seed": 3,
        "node_embed_size": 32,
        "structure_patch_type": "triangular_random_walk",
        "lstm_aggregator": "last",
        "n_processes": 20,
        "resample_anchor_patches": false,
        "freeze_node_embeds":false,
        "use_mpn_projection":true,
        "print_train_times":false,
        "compute_similarities":false,
        "sample_walk_len":50,
        "n_triangular_walks": 5, 
        "random_walk_len":10,  
        "rw_beta" : 0.65,
        "ff_attn": false,
        "max_sim_epochs": 5,
        "embedding_type": "gin"    
    
    },

    "hyperparams_optuna": {
        "batch_size" :{
            "type" : "suggest_categorical",
            "args" : [[ 128, 512] ]
        },
        "learning_rate" :{
            "type" : "suggest_float",
            "args" : [1e-4, 1e-3],
            "kwargs" : {"log":true}
        },
        "grad_clip" : {
            "type" : "suggest_float",
            "args" : [0.0, 0.5]
        },
        "n_layers": {
            "type" : "suggest_int",
            "args" : [1,5]
        },
        "neigh_sample_border_size" : {
            "type" : "suggest_int",
            "args" : [1,2]
        },
        "n_anchor_patches_pos_out": {
            "type" : "suggest_int",
            "args" : [50,200]
        }, 
        "n_anchor_patches_pos_in": {
            "type" : "suggest_int",
            "args" : [25,75]
        },
        "n_anchor_patches_N_in": {
            "type" : "suggest_int",
            "args" : [10,25]
        }, 
        "n_anchor_patches_N_out": {
            "type" : "suggest_int",
            "args" : [25,75]
        }, 
        "n_anchor_patches_structure": {
            "type" : "suggest_int",
            "args" : [15,45]
        }, 
        "linear_hidden_dim_1" : {
            "type" : "suggest_categorical",
            "args" : [[64]]
        },
        "linear_hidden_dim_2" : {
            "type" : "suggest_categorical",
            "args" : [[32, 64]]
        },
        "lstm_dropout" : {
            "type" : "suggest_float",
            "args" : [0.0, 0.4]
        },
        "lstm_n_layers" : {
            "type" : "suggest_int",
            "args" : [1,2]
        },
        "lin_dropout" : {
            "type" : "suggest_float",
            "args" : [0.0, 0.4]
        },
        "cc_aggregator":{
            "type" : "suggest_categorical",
            "args" : [[ "sum","max"] ]
        },
        "trainable_cc":{
            "type" : "suggest_categorical",
            "args" : [[ true,false] ]
        },
        "auto_lr_find":{
            "type" : "suggest_categorical",
            "args" : [[ true,false] ]
        }
    }

}
